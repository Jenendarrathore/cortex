# ── Database ──────────────────────────────────────────────────────────────────
# For local (make setup) the host is localhost.
# For docker compose the backend reaches Postgres at host "postgres".
PGHOST=localhost
PGPORT=5432
PGDATABASE=cortex_rag
PGUSER=raguser
PGPASSWORD=change_me

# ── Services ──────────────────────────────────────────────────────────────────
# Local defaults shown. Under docker compose use the service names:
#   OLLAMA_URL=http://ollama:11434   REDIS_URL=redis://redis:6379
OLLAMA_URL=http://localhost:11434
REDIS_URL=redis://localhost:6379
EMBED_MODEL=nomic-embed-text

# ── Auth (optional) ───────────────────────────────────────────────────────────
# If set, every API route requires the X-API-Key header.
# API_KEY=your_secret_key_here

# Comma-separated CORS origins, or "*" to allow all.
CORS_ORIGINS=http://localhost:5173

# ── Host ports (docker compose) ───────────────────────────────────────────────
# Only the published host side. Change if a port is already in use on your box.
# (e.g. something else owns 3000 -> set DOCS_PORT=3001)
# BACKEND_PORT=8002
# FRONTEND_PORT=5173
# MCP_HOST_PORT=8001
# DOCS_PORT=3000

# ── Licensing (OFF by default) ────────────────────────────────────────────────
# The open-source build boots with no license. Leave this off.
# Only set LICENSE_ENABLED=true if you run a license server.
LICENSE_ENABLED=false
# LICENSE_KEY=
# LICENSE_SERVER_URL=https://license.example.com
# LICENSE_CHECK_INTERVAL_HOURS=24
